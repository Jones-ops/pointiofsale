# POS Backend Configuration
# Copy this file to .env and modify as needed

# Server port (default: 3001)
# PORT=3001

# JWT secret key (change in production!)
JWT_SECRET=pos-system-secret-key-change-in-production

# Database configuration
# Leave DATABASE_URL unset to use SQLite (file stored in backend/data/pos.db)
# Set DATABASE_URL to use PostgreSQL (for multi-computer concurrent access)
# DATABASE_URL=postgresql://user:password@localhost:5432/pos_db
